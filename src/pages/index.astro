---
import Base from '../layouts/Base.astro';
---

<Base current="home">
  <section class="mx-auto max-w-6xl px-6 py-24 md:py-40">
    <p class="text-sm uppercase tracking-[0.2em] text-accent mb-6">Baji Tumendemberel</p>
    <h1 class="font-display text-6xl md:text-8xl leading-none tracking-tight mb-8">
      Data science<br />
      <span class="text-white/50">at the intersection of</span><br />
      social justice.
    </h1>
    <p class="text-lg md:text-xl text-white/70 max-w-2xl leading-relaxed mb-10">
      Yale '22 graduate using statistical methods and computational tools to surface patterns
      of inequity, support legal advocacy, and inform policy that affects underserved
      communities. Selected work spans civil-rights litigation, public-health transparency,
      and the politics of who gets counted.
    </p>
    <div class="flex flex-wrap gap-4">
      <a href="/projects" class="inline-block px-6 py-3 bg-accent text-black font-medium hover:bg-white transition-colors">
        View projects
      </a>
      <a href="/about" class="inline-block px-6 py-3 border border-white/20 hover:border-white transition-colors">
        About me
      </a>
    </div>
  </section>
</Base>
